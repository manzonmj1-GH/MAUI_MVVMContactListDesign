<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_MVMContactListDesign.Views.AddContactPage"
             Title="Add Contact Page">
    
    <VerticalStackLayout Padding="20" Spacing="10">

        <Entry Placeholder="Name" Text="{Binding Name}"/>
        <Entry Placeholder="Email" Text="{Binding Email}"/>
        <Entry Placeholder="Phone" Text="{Binding Phone}"/>
        <Editor Placeholder="Description" Text="{Binding Description}"/>

        <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="Green"/>
    </VerticalStackLayout>
</ContentPage>